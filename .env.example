# ─── Server ───────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/laspero

# ─── JWT ──────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key

# ─── Stripe ────────────────

# ─── Email (Nodemailer / Gmail SMTP) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Laspero <noreply@laspero.com>

# ─── Frontend URL (for CORS + email links) ────────
CLIENT_URL=http://localhost:5173

# ─── Cookie ───────────────────────────────────────
COOKIE_SECURE=false
